generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model UserSettings {
  id             String   @id @default("global")
  deepseekApiKey String?
  apifyApiKey    String?
  rapidApiKey    String?
  serpApiKey     String?
  resumeText     String?
  goalsText      String?
  locationsText  String?
  updatedAt      DateTime @updatedAt
}

model Job {
  id          String  @id @default(uuid())
  title       String
  company     String
  description String?
  location    String?
  url         String?
  source      String?
  sourceId    String?
  manualAts   String?

  canonicalUrl String?
  fingerprint  String?

  postedAt           DateTime
  status             String   @default("pending_af")
  verificationStatus String   @default("pending")

  contextBatched Boolean   @default(false)
  afBatchId      String?
  jdBatchId      String?
  cooldownUntil  DateTime?

  scoringStatus String  @default("queued")
  scoreAttempts Int     @default(0)
  scoreError    String?

  fitScore          Int?
  aimFitScore       Int?
  fitCategory       String  @default("unscored")
  fitRationale      String?
  tailoringAdvice   String?
  recommendedResume String?
  tailoringStaged   Boolean @default(false)
  submittedResume   String?
  contextPacket     String?
  passReason        String?

  reqFitScore      Int?
  reqFitRationale  String?
  travelScore      Int?
  experienceStatus String  @default("queued")
  batchJobId       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  observations JobSourceObservation[]
}

model JobSourceObservation {
  id       String  @id @default(uuid())
  jobId    String
  source   String
  sourceId String
  url      String?
  job      Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([source, sourceId])
}

model UserPreference {
  id        String   @id @default(uuid())
  text      String
  type      String
  createdAt DateTime @default(now())
}

model UsageTracking {
  id           String @id @default(uuid())
  date         String @unique
  tokens       Int    @default(0)
  inputTokens  Int    @default(0)
  outputTokens Int    @default(0)
  cost         Float  @default(0)
}

model AtsCompany {
  slug          String
  platform      String
  status        String    @default("active")
  failCount     Int       @default(0)
  nextCheckDate DateTime  @default(now())
  lastCheckedAt DateTime?
  jobsFound     Int       @default(0)
  discoveredAt  DateTime  @default(now())

  @@id([slug, platform])
}

model ContextProfile {
  id         String   @id @default("global")
  rulesText  String
  updatedAt  DateTime @updatedAt
  batchJobId String?
}
